{
    "compilerOptions": {
        "allowJs": true,
        "module": "ESNext",
        "moduleResolution": "bundler",
        "jsx": "preserve",
        "strict": true,
        "isolatedModules": true,
        "target": "ESNext",
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "noEmit": true,
        "skipLibCheck": true,
        "paths": {
            "@/*": ["./app/*"]
        },
        "types": ["vite/client", "@vue-macros/reactivity-transform/macros-global"]
    },
    "include": ["app/**/*.ts", "app/**/*.d.ts", "app/**/*.vue"]
}
